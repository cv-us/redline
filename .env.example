# Vercel AI Gateway — single key fronts Anthropic/Google/OpenAI traffic.
# Get from: Vercel dashboard → AI Gateway → API Keys.
AI_GATEWAY_API_KEY=

# Neon Postgres (with pgvector). Pooled URL for app traffic; unpooled for migrations.
# Get from: Neon dashboard → Connection details.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Vercel Blob (auto-injected on Vercel, set locally for dev).
# Get from: Vercel dashboard → Storage → Blob → .env.local snippet.
BLOB_READ_WRITE_TOKEN=

# Slack (Phase 7).
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# MCP server bearer (Phase 8). Generate any high-entropy string.
MCP_BEARER_TOKEN=
